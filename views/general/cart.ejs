<div class="max-w-5xl mx-auto px-4 py-10">
  
    <% if (message) { %>
      <div class="alert alert-info mb-6">
        <span><%= message %></span>
      </div>
    <% } %>
  
    <% if (!hasMealKits) { %>
      <div class="card bg-base-100 shadow border border-base-300">
        
        <div class="flex justify-center mb-20">
            <span>Welcome <%= user.firstName %> <%= user.lastName %>, ready to shop!</span>
        </div>

        <div class="card-body text-center">
          <h2 class="card-title justify-center">Your cart is empty</h2>
          <p>Add some meal kits to get started.</p>
          <div class="card-actions justify-center mt-4">
            <a href="/mealkits" class="btn btn-primary">Browse Meal Kits</a>
          </div>
        </div>
      </div>
    <% } else { %>
  
      <div class="space-y-6">
        <% mealKits.forEach(meal => { %>
          <div class="card bg-base-100 shadow border border-base-300">
            <div class="card-body">
              <div class="flex flex-col md:flex-row gap-6 items-center md:items-start">
                <img
                  src="<%= meal.mealKit.imageUrl %>"
                  alt="<%= meal.mealKit.title %>"
                  class="w-32 h-32 object-cover rounded-lg"
                >
  
                <div class="flex-1 w-full">
                  <h2 class="text-xl font-bold"><%= meal.mealKit.title %></h2>
                  <textarea class="text-sm text-base-content/70 mt-1" readonly><%= meal.mealKit.includes %></textarea>
                  <p class="text-sm text-base-content">Unit Price: $<%= meal.mealKit.price.toFixed(2) %> </p>
                  <p class="text-sm text-base-content">Total: $<%= (meal.mealKit.price * meal.qty).toFixed(2) %> </p>
                </div>
  
                <div class="flex flex-col gap-3 w-full md:w-auto">
                  <form method="POST" action="/cart/update/<%= meal._id %>" class="flex items-center gap-2">
                    <label class="text-sm font-medium">Qty</label>
                    <input
                      type="number"
                      name="qty"
                      value="<%= meal.qty %>"
                      min="1"
                      class="input input-bordered w-20"
                    >
                    <button type="submit" class="btn btn-primary btn-sm">Update</button>
                  </form>
  
                  <form method="get" action="/cart/remove/<%= meal._id %>">
                    <button type="submit" class="btn btn-error btn-sm w-full">Remove</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
  
      <div class="card bg-base-100 shadow border border-base-300 mt-8 max-w-md ml-auto">
        <div class="card-body">
          <h2 class="card-title">Order Summary</h2>
          <p>Subtotal: $<%= subtotal.toFixed(2) %></p>
          <p>Tax (10%): $<%= tax.toFixed(2) %></p>
          <p class="font-bold text-lg">Grand Total: $<%= cartTotal.toFixed(2) %></p>
  
          <form method="POST" action="/cart/place-order" class="mt-4">
            <button type="submit" class="btn btn-success w-full">Place Order</button>
          </form>
        </div>
      </div>
  
    <% } %>
  </div>